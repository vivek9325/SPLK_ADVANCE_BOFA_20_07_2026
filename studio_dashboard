        "ds_nhBlyJXG": {
            "name": "Count By hits and Visitors search",
            "options": {
                "query": "index=web action=purchase categoryId=$category_id$ productId IN ($pid$,$tok1$) \n| timechart span=1H count AS hits, dc(clientip) AS visitors",
