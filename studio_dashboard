            "name": "Count of CategoryId and ProductId - Table search",
            "options": {
                "query": "index=$idx$ status=$status$\n| stats count by categoryId, productId\n|sort count\n|head 5\n| chart values(count) OVER categoryId BY productId\n| fillnull",
